# Per-machine secrets — copy this to .env.local and fill in values below.
# .env.local is git-ignored and should never be committed.
#
# Sensitive values should be AES-256-GCM encrypted using the encsecret CLI:
#   go run ./cmd/encsecret -encrypt -value "plaintext_secret"
# Then replace the plaintext with the encrypted ENC[...] output.
#
# To decrypt values in .env.local:
#   go run ./cmd/encsecret -decrypt -value "ENC[...]"

# Master key (32 bytes / 64 hex chars) — required to decrypt ENC[...] values at startup
MASTER_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Primary tenant database (mmff_vector)
# DEV PORT — 5435 = dev VPS via `ssh -fN vector-dev-pg`. Staging :5436 and
# production :5434 are hardlocked off (2026-05-05); never use those ports here.
DB_HOST=localhost
DB_PORT=5435
DB_NAME=mmff_vector
DB_USER=ENC[...]
DB_PASSWORD=ENC[...]

# JWT secrets for access and refresh tokens
JWT_ACCESS_SECRET=ENC[...]
JWT_REFRESH_SECRET=ENC[...]
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Application environment and server config
APP_ENV=development
SERVER_PORT=5100
FRONTEND_ORIGIN=http://localhost:5101
COOKIE_SECURE=false

# Authentication lockout settings
RESET_TOKEN_TTL=1h
LOCKOUT_THRESHOLD=5
LOCKOUT_DURATION=15m

# Email/SMTP configuration
SMTP_HOST=mail.mmffdev.com
SMTP_PORT=465
SMTP_USER=ENC[...]
SMTP_PASS=ENC[...]
SMTP_FROM=no-reply@mmffdev.com
EMAIL_MODE=smtp

# mmff_library — read pool (every request) — DEV PORT 5435 (see DB_PORT note above)
LIBRARY_DB_HOST=localhost
LIBRARY_DB_PORT=5435
LIBRARY_DB_NAME=mmff_library
LIBRARY_DB_USER=ENC[...]
LIBRARY_DB_PASSWORD=ENC[...]

# mmff_library — publish pool (Phase 5 publish + share endpoints)
LIBRARY_PUBLISH_DB_USER=ENC[...]
LIBRARY_PUBLISH_DB_PASSWORD=ENC[...]

# mmff_library — ack pool (Phase 3.5+ acknowledgement handler)
LIBRARY_ACK_DB_USER=ENC[...]
LIBRARY_ACK_DB_PASSWORD=ENC[...]

# Search-index outbox worker — embeds artefact text via local Ollama.
# Consumed by backend/internal/searchworker/worker.go. main.go falls back to
# these same defaults when unset.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text
