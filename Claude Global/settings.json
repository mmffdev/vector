{
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "WebSearch",
      "WebFetch(domain:localhost)",
      "Bash(curl -sf http://localhost:3344/api/status)",
      "Bash(curl -sf http://localhost:5002/api/health)",
      "Bash(curl -sf http://localhost:5001/api/health)",
      "Bash(curl -sf \"http://localhost:3344/api/dev/auth/current\")",
      "Bash(curl -sf http://localhost:3344/api/dev/users)",
      "Bash(sed 's|backend/data/wppc\\\\.db|backend/data/ops.db|g' ~/.claude/c_mstories-protocol.md)",
      "Bash(sed 's|backend/data/wppc\\\\.db|backend/data/ops.db|g' ~/.claude/c_defect-protocol.md)",
      "Bash(cp /tmp/state.md.orig .claude/commands/state.md)",
      "Bash(git add *)",
      "Edit(/.claude/skills/uglobal/**)",
      "Edit(/.claude/skills/ubackend/**)",
      "Edit(/.claude/skills/ufrontend/**)",
      "Edit(/.claude/skills/udocs/**)",
      "Bash(cp /tmp/sprint-start.orig .claude/commands/sprint-start.md)",
      "Bash(git show *)",
      "Edit(/.claude/skills/auditmd/**)",
      "Bash(rm -v {{HOME}}/Documents/MMFFDev-Projects/mmff-Ops/.claude/commands/ubackend.md)",
      "Bash(rm -v {{HOME}}/Documents/MMFFDev-Projects/mmff-Ops/.claude/commands/ufrontend.md)",
      "Bash(rm -v {{HOME}}/Documents/MMFFDev-Projects/mmff-Ops/.claude/commands/uglobal.md)",
      "Bash(rm -v {{HOME}}/Documents/MMFFDev-Projects/mmff-Ops/.claude/commands/udocs.md)",
      "Edit(/.claude/skills/uresearch/**)",
      "Edit(/.claude/skills/backupdb/**)",
      "Edit(/.claude/skills/restoredb/**)",
      "Edit(/.claude/skills/failover/**)"
    ],
    "additionalDirectories": [
      "/tmp",
      "{{HOME}}/.claude",
      "{{HOME}}/Library/Application Support/Code/User",
      "{{HOME}}/Documents/MMFFDev-Projects/MMFFDev-WPPC/.claude",
      "{{HOME}}/Documents/MMFFDev-Projects/MMFFDev-WPPC/.claude/handoffs",
