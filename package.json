{
  "name": "mmff-pm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo -p 5101",
    "build": "next build",
    "start": "next start -p 5101",
    "lint": "next lint",
    "lint:addressables": "python3 dev/scripts/lint_addressables.py",
    "lint:role-literals": "python3 dev/scripts/lint_role_literals.py",
    "lint:writer-boundary": "python3 dev/scripts/lint_writer_boundary.py",
    "lint:dev-css": "python3 dev/scripts/lint_dev_css.py",
    "lint:secondary-nav": "python3 dev/scripts/lint_secondary_nav.py",
    "lint:no-raw-table": "python3 dev/scripts/lint_no_raw_table.py",
    "lint:tab-deep-link": "python3 dev/scripts/lint_tab_deep_link.py",
    "lint:portfolio-library-read": "python3 dev/scripts/lint_portfolio_library_read.py",
    "lint:scope-literals": "python3 dev/scripts/lint_scope_literals.py",
    "lint:public-helper-allowlist": "python3 dev/scripts/lint_public_helper_allowlist.py",
    "lint:no-db-in-handlers": "python3 dev/scripts/lint_no_db_in_handlers.py",
    "lint:public-dto-mapper": "python3 dev/scripts/lint_public_dto_mapper.py",
    "lint:page-description": "python3 dev/scripts/lint_page_description.py",
    "lint:h2-panel-only": "python3 dev/scripts/lint_h2_panel_only.py",
    "lint:sql-in-sqlfile-only": "python3 dev/scripts/lint_sql_in_sqlfile_only.py",
    "lint:no-empty-route-block": "python3 dev/scripts/lint_no_empty_route_block.py",
    "lint:exemption-ratchet": "python3 dev/scripts/lint_exemption_ratchet.py",
    "lint:deferral-needs-td-id": "python3 dev/scripts/lint_deferral_needs_td_id.py",
    "lint:package-naming-convention": "python3 dev/scripts/lint_package_naming_convention.py",
    "lint:column-prefix-convention": "python3 dev/scripts/lint_column_prefix_convention.py",
    "lint:cross-db-writer-test": "python3 dev/scripts/lint_cross_db_writer_test.py",
    "lint:rf1": "npm run lint:sql-in-sqlfile-only && npm run lint:no-empty-route-block && npm run lint:exemption-ratchet && npm run lint:package-naming-convention && npm run lint:cross-db-writer-test && npm run lint:column-prefix-convention",
    "api:snap": "bash dev/scripts/snap_api.sh",
    "api:check": "bash dev/scripts/check_routes.sh --all && python3 dev/scripts/check_callers.py --all",
    "api:check:v1": "bash dev/scripts/check_routes.sh --spec openapi.yaml && python3 dev/scripts/check_callers.py --spec openapi.yaml",
    "api:check:v2": "bash dev/scripts/check_routes.sh --spec openapi-v2.yaml && python3 dev/scripts/check_callers.py --spec openapi-v2.yaml",
    "api:install-hooks": "cp dev/scripts/pre-push.sh .git/hooks/pre-push && chmod +x .git/hooks/pre-push && echo 'pre-push hook installed'",
    "audit:dashboard": "python3 dev/scripts/audit_dashboard.py",
    "audit:field-library": "PGPASSWORD=$(grep '^DB_PASSWORD=' backend/.env.local | cut -d= -f2-) /opt/homebrew/opt/libpq/bin/psql -h localhost -p 5435 -U mmff_dev -d vector_artefacts -f dev/scripts/audit_field_library_orphans.sql",
    "e2e": "node --test --test-reporter=spec 'e2e/**/*.spec.mjs'",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@heroicons/react": "^2.2.0",
    "@types/d3-selection": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@xyflow/react": "^12.10.2",
    "3d-force-graph": "^1.80.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "dagre": "^0.8.5",
    "feather-icons": "^4.29.2",
    "framer-motion": "^12.38.0",
    "gsap": "^3.15.0",
    "iconoir": "^7.11.0",
    "isomorphic-dompurify": "^3.13.0",
    "lucide-react": "^1.14.0",
    "next": "^15.0.0",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-feather": "^2.0.10",
    "react-icons": "^5.6.0",
    "sonner": "^2.0.7",
    "three": "^0.184.0",
    "three-spritetext": "^1.10.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3-zoom": "^3.0.8",
    "@types/dagre": "^0.7.54",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/selenium-webdriver": "^4.1.28",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^25.0.1",
    "marked": "^18.0.2",
    "selenium-webdriver": "^4.27.0",
    "typescript": "^5",
    "vitest": "^2.1.9"
  }
}
