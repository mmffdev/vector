#!/usr/bin/env bash
# git pre-commit hook — runs registry lint(s) before each commit.
# Tracked source; .git/hooks/pre-commit is a symlink to this file.
# Each lint writes a report to dev/reports/ so the Dev → Reports tab
# always shows the latest result. A non-zero exit blocks the commit.

set -e
ROOT="$(git rev-parse --show-toplevel)"

if ! python3 "$ROOT/dev/scripts/lint_addressables.py" --report; then
  echo "" >&2
  echo "Commit blocked by lint:addressables — wrap the raw panel shape(s)" >&2
  echo "above in <Panel name='…'> from app/components/Panel.tsx, or add" >&2
  echo "the file to dev/registries/addressables_exempt.json with a" >&2
  echo "justification (the exemption list is normally empty)." >&2
  exit 1
fi

# ── API spec auto-sync ─────────────────────────────────────────────────
# When the commit touches a Go file that contributes to the route
# catalogue, re-run `npm run api:sync` and auto-stage the regenerated
# specs into the same commit. This guarantees the spec never falls out
# of sync with `main.go` — if you add a route, the YAML moves with it,
# and the pre-push contract gate stays green.
#
# Trigger files: backend/cmd/server/main.go (routing) + every
# backend/internal/<pkg>/*.go (handler shapes).
STAGED=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null || true)
NEEDS_API_SYNC=0
if echo "$STAGED" | grep -qE '^backend/cmd/server/main\.go$|^backend/internal/.*\.go$'; then
  NEEDS_API_SYNC=1
fi

if [[ "$NEEDS_API_SYNC" == "1" ]]; then
  echo "[pre-commit] Backend route surface changed — running npm run api:sync …"
  if ! ( cd "$ROOT" && npm run api:sync >/dev/null 2>&1 ); then
    echo "" >&2
    echo "Commit blocked: 'npm run api:sync' failed." >&2
    echo "Run it manually and resolve the errors:" >&2
    echo "    npm run api:sync" >&2
    exit 1
  fi
  # Re-stage any regenerated artefacts. This is the auto-magic: the
  # human edits main.go, the spec catches up in the same commit.
  for f in siteAPI.yaml samanthaAPI.yaml \
           api-reference/static/siteAPI.yaml api-reference/static/samanthaAPI.yaml; do
    if [[ -f "$ROOT/$f" ]] && ! git diff --quiet -- "$ROOT/$f" 2>/dev/null; then
      git add "$ROOT/$f"
      echo "  [pre-commit] auto-staged regenerated $f"
    fi
  done
fi

exit 0
